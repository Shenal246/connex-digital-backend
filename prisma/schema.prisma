generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// IAM: Users & Roles
// -----------------------------------------------------------------------------

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  isActive     Boolean @default(true)
  passwordHash String?
  name         String?

  // Security & MFA
  mfaEnabled             Boolean   @default(false)
  mfaSecret              String?
  isInvited              Boolean   @default(false)
  failedLoginAttempts    Int       @default(0)
  lockedOutUntil         DateTime?
  mustChangePassword     Boolean   @default(false)
  otpSecret              String?
  otpExpiresAt           DateTime?
  resetPasswordToken     String?
  resetPasswordExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roleId        String?
  role          Role?                 @relation(fields: [roleId], references: [id])
  employeeId    String?               @unique
  employee      Employee?             @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  auditLogs     AuditLog[]
  notifications Notification[]
  articleVotes  HelpArticleVote[]
  refreshTokens RefreshToken[]
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions   RolePermission[]
  users         User[]
}

// Stored refresh token hashes for revocation support
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique   // SHA-256 hash of the raw refresh JWT
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// IAM: Dynamic Navigation & Security
// -----------------------------------------------------------------------------

model SystemModule {
  id        String   @id @default(uuid())
  name      String   @unique
  key       String   @unique // e.g. "iam", "hr_operations"
  icon      String? // Lucide icon name
  route     String? // e.g. "/admin" (parent route)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resources Resource[]
}

model Resource {
  id       String       @id @default(uuid())
  name     String
  key      String // e.g. "users", "roles"
  moduleId String
  module   SystemModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([moduleId, key])
}

model Permission {
  id         String   @id @default(uuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  action     String // e.g. "CREATE", "READ", "UPDATE", "DELETE", "APPROVE"
  createdAt  DateTime @default(now())

  roles RolePermission[]

  @@unique([resourceId, action])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String
  policyJson   Json? // optional field-level/row-level policies

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// -----------------------------------------------------------------------------
// Audit Log
// -----------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  status     String // SUCCESS/FAIL
  ip         String?
  userAgent  String?
  requestId  String?
  metadata   Json? // extra details

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
}

// -----------------------------------------------------------------------------
// HR: Organization Setup
// -----------------------------------------------------------------------------

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  parentDeptId String?
  managerId   String? // User ID or Employee ID

  parentDept  Department?  @relation("SubDepartments", fields: [parentDeptId], references: [id])
  subDepts    Department[] @relation("SubDepartments")
  
  designations Designation[]
  employees    Employee[]
  
  history      EmploymentHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Designation {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  departmentId String?
  
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  history      EmploymentHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// HR: Employee Core
// -----------------------------------------------------------------------------

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
  PROBATION
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Employee {
  id           String         @id @default(uuid())
  employeeId   String         @unique // Custom business ID
  user         User?
  // Personal Info
  firstName    String
  lastName     String
  middleName   String?
  displayName  String?
  gender       Gender
  dateOfBirth  DateTime
  maritalStatus String?
  bloodGroup   String?
  
  // Employment Info
  status       EmployeeStatus @default(PROBATION)
  joinDate     DateTime
  exitDate     DateTime?
  
  departmentId  String
  designationId String
  
  department    Department  @relation(fields: [departmentId], references: [id])
  designation   Designation @relation(fields: [designationId], references: [id])

  // Reporting Structure
  reportsToId   String?
  reportsTo     Employee?   @relation("EmployeeHierarchy", fields: [reportsToId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  directReports Employee[]  @relation("EmployeeHierarchy")
  
  // Relationships
  addresses         EmployeeAddress[]
  bankDetails       EmployeeBankDetails?
  emergencyContacts EmployeeEmergencyContact[]
  history           EmploymentHistory[]
  documents         EmployeeDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeAddress {
  id          String   @id @default(uuid())
  employeeId  String
  type        String   @default("CURRENT") // CURRENT, PERMANENT, OFFICE
  addressLine1 String
  addressLine2 String?
  city         String
  state        String?
  zipCode      String?
  country      String   @default("Sri Lanka")

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmployeeBankDetails {
  id            String   @id @default(uuid())
  employeeId    String   @unique
  accountName   String
  accountNumber String
  bankName      String
  branchName    String?
  swiftCode     String?

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmployeeEmergencyContact {
  id           String   @id @default(uuid())
  employeeId   String
  name         String
  relationship String
  phoneNumber  String

  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmploymentHistory {
  id            String   @id @default(uuid())
  employeeId    String
  departmentId  String
  designationId String
  startDate     DateTime
  endDate       DateTime?
  salary        Decimal?  @db.Decimal(10, 2)
  changeReason  String?   // PROMOTION, TRANSFER, SALARY_REVISION

  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department    Department  @relation(fields: [departmentId], references: [id])
  designation   Designation @relation(fields: [designationId], references: [id])
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeId   String
  title        String
  documentType String   // NIC, PASSPORT, CONTRACT, CERTIFICATE
  fileUrl      String
  fileSize     Int?
  uploadedAt   DateTime @default(now())

  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Notifications
// -----------------------------------------------------------------------------

model Notification {
  id      String  @id @default(uuid())
  userId  String
  title   String
  message String
  type    String  @default("INFO") // INFO, SUCCESS, WARNING, ERROR, ACTION
  isRead  Boolean @default(false)
  linkUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}
// -----------------------------------------------------------------------------
// Help Center
// -----------------------------------------------------------------------------

model HelpCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String? // Lucide icon name
  order       Int      @default(0)
  isAdminOnly Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles HelpArticle[]
}

model HelpArticle {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  categoryId  String
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  isAdminOnly Boolean  @default(false)
  helpfulCount    Int      @default(0)
  notHelpfulCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  votes           HelpArticleVote[]

  category HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([slug])
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isAdminOnly Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HelpArticleVote {
  id        String   @id @default(uuid())
  articleId String
  userId    String
  isHelpful Boolean
  createdAt DateTime @default(now())

  article HelpArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
}
